# LLM
OPENAI_API_KEY=sk-...

# LangSmith observability (new SDK uses LANGSMITH_ prefix)
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=rag-poc-v2
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Vector backend: "chroma" (default, local) or "pgvector" (Supabase prod)
VECTOR_BACKEND=chroma

# ChromaDB (used when VECTOR_BACKEND=chroma)
CHROMA_PERSIST_DIR=./chroma_data

# Supabase (used when VECTOR_BACKEND=pgvector, or for file storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Reranking - optional, falls back to cross-encoder if not set
COHERE_API_KEY=

# Knowledge base path (relative to backend/)
KNOWLEDGE_BASE_DIR=../knowledge-base
